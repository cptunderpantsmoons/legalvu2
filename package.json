{
  "name": "legal-wrkspace",
  "version": "1.0.0",
  "description": "AI-powered legal workspace for contract lifecycle management",
  "main": ".vite/build/index.js",
  "scripts": {
    "dev": "NODE_ENV=development electron-forge start",
    "build": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx electron-rebuild -f -w better-sqlite3 && xvfb-run npx playwright test",
    "rebuild:electron": "npx electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "build:renderer": "vite build --config vite.renderer.config.ts --outDir .vite/renderer --emptyOutDir",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "src/**/*.ts": ["eslint --fix", "prettier --write"],
    "src/**/*.tsx": ["eslint --fix", "prettier --write"]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-vite": "^7.5.0",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.0.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "marked": "^18.0.5",
    "playwright": "^1.61.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.0",
    "tiptap-markdown": "^0.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  }
}
